NODE_ENV=development
APP_NAME=NOVAEX API
APP_PORT=4000
APP_GLOBAL_PREFIX=api
APP_VERSION=v1
APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
RUN_MIGRATIONS=true

DATABASE_URL=postgresql://novaex_user:novaex_password@postgres:5432/novaex?schema=public
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=novaex-docker-jwt-access-secret-32chars-min
JWT_REFRESH_SECRET=novaex-docker-jwt-refresh-secret-32chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_REMEMBER_ME_EXPIRES_IN=90d
COOKIE_SECRET=novaex-docker-cookie-secret-32chars-minimum
CSRF_ENABLED=false

BETTER_AUTH_SECRET=novaex-docker-better-auth-secret-32chars-min
BETTER_AUTH_URL=http://localhost:4000

MFA_ISSUER=NOVAEX
PASSWORD_EXPIRY_DAYS=90
EMAIL_VERIFICATION_TTL_MINUTES=60
PASSWORD_RESET_TTL_MINUTES=30
MAGIC_LINK_TTL_MINUTES=15
OTP_TTL_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_WINDOW_MS=900000
LOCKOUT_DURATION_MS=1800000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:4000

CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=demo-key
CLOUDINARY_API_SECRET=demo-secret

STRIPE_SECRET_KEY=sk_test_docker_placeholder_key
STRIPE_WEBHOOK_SECRET=whsec_docker_placeholder_secret
STRIPE_PUBLISHABLE_KEY=pk_test_docker_placeholder_key

RESEND_API_KEY=re_docker_placeholder_key
MAIL_FROM=NOVAEX <no-reply@novaex.ai>

RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
LOG_LEVEL=info
ENABLE_TEST_PAYMENT_SIMULATION=true
