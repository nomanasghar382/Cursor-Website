NODE_ENV=development
APP_NAME=NOVAEX API
APP_PORT=4000
APP_GLOBAL_PREFIX=api
APP_VERSION=v1
APP_BASE_URL=http://localhost:4000
WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgresql://novaex_user:novaex_password@localhost:5432/novaex?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=replace-with-64-character-access-secret
JWT_REFRESH_SECRET=replace-with-64-character-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=replace-with-64-character-cookie-secret
CSRF_ENABLED=false

BETTER_AUTH_SECRET=replace-with-64-character-better-auth-secret
BETTER_AUTH_URL=http://localhost:4000

CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

RESEND_API_KEY=re_replace_me
MAIL_FROM=NOVAEX <no-reply@novaex.ai>

RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
LOG_LEVEL=info
