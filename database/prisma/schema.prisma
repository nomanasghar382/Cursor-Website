generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  PENDING
  BLOCKED
  DELETED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  PASSKEY
}

enum RoleScope {
  GLOBAL
  VENDOR
  STORE
}

enum UserRoleType {
  CUSTOMER
  SELLER
  SELLER_ADMIN
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum StoreStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum ProductVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum VariantStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum AttributeDataType {
  TEXT
  NUMBER
  BOOLEAN
  COLOR
  SIZE
  JSON
}

enum MovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RESERVATION
  RELEASE
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  REQUIRES_ACTION
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentGateway {
  STRIPE
  PAYPAL
  MANUAL
}

enum TransactionType {
  AUTHORIZE
  CAPTURE
  REFUND
  VOID
  CHARGEBACK
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  COMPLETED
}

enum RefundStatus {
  PENDING
  APPROVED
  PROCESSED
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum CouponStatus {
  DRAFT
  ACTIVE
  EXPIRED
  DISABLED
}

enum GiftCardStatus {
  ACTIVE
  DISABLED
  EXPIRED
  DEPLETED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum Direction {
  LTR
  RTL
}

model User {
  id              String        @id @default(uuid()) @db.Uuid
  email           String        @unique @db.Citext
  phone           String?       @unique
  passwordHash    String?       @map("password_hash")
  authProvider    AuthProvider  @default(EMAIL) @map("auth_provider")
  status          UserStatus    @default(PENDING)
  emailVerifiedAt DateTime?     @map("email_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt DateTime?     @map("phone_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?     @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)
  metadata        Json?

  profile              UserProfile?
  addresses            UserAddress[]
  roles                UserRole[]
  sessions             Session[]
  refreshTokens        RefreshToken[]
  apiKeys              ApiKey[]
  carts                ShoppingCart[]
  wishlists            Wishlist[]
  recentlyViewed       RecentlyViewedProduct[]
  aiRecommendations    AiRecommendation[]
  aiChatSessions       AiChatSession[]
  searchHistory        SearchHistory[]
  voiceSearches        VoiceSearch[]
  imageSearches        ImageSearch[]
  orders               Order[]
  returns              Return[]
  couponRedemptions    CouponRedemption[]
  reviews              Review[]
  questions            Question[]
  answers              Answer[]
  notifications        Notification[]
  referralsMade        Referral[]             @relation("Referrer")
  referralsReceived    Referral[]             @relation("Referred")
  rewardPoints         RewardPoint[]
  affiliate            Affiliate?
  auditLogs            AuditLog[]
  activityLogs         ActivityLog[]
  securityLogs         SecurityLog[]
  authoredBlogs        Blog[]
  blogComments         BlogComment[]
  stockMovements       StockMovement[]
  reports              Report[]
  vendorMemberships    VendorUser[]
  vendorEmployees      VendorEmployee[]
  compareLists         CompareList[]
  newsletterSubscriptions NewsletterSubscription[]
  subscriptions        Subscription[]
  analyticsEvents      AnalyticsEvent[]

  @@index([status, createdAt])
  @@index([lastLoginAt])
  @@map("users")
}

model UserProfile {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  avatarUrl           String?   @map("avatar_url")
  dateOfBirth         DateTime? @map("date_of_birth") @db.Date
  gender              String?
  preferredLanguageId String?   @map("preferred_language_id") @db.Uuid
  preferredCurrencyId String?   @map("preferred_currency_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)
  metadata            Json?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredLanguage Language? @relation(fields: [preferredLanguageId], references: [id], onDelete: SetNull)
  preferredCurrency Currency? @relation(fields: [preferredCurrencyId], references: [id], onDelete: SetNull)

  @@map("user_profiles")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  type        UserRoleType @default(CUSTOMER)
  description String?
  scope       RoleScope    @default(GLOBAL)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)
  metadata    Json?

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([scope])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  metadata    Json?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  vendorId  String?   @map("vendor_id") @db.Uuid
  storeId   String?   @map("store_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  store  Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, vendorId, storeId])
  @@index([userId])
  @@index([roleId])
  @@index([vendorId])
  @@index([storeId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash")
  ipAddress        String?   @map("ip_address") @db.Inet
  userAgent        String?   @map("user_agent")
  deviceId         String?   @map("device_id")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  rotatedAt DateTime? @map("rotated_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Country {
  id        String   @id @default(uuid()) @db.Uuid
  iso2      String   @unique @db.Char(2)
  iso3      String   @unique @db.Char(3)
  name      String
  phoneCode String?  @map("phone_code")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cities        City[]
  addresses     UserAddress[]
  warehouses    Warehouse[]
  shippingZones ShippingZone[]
  taxRates      TaxRate[]

  @@index([isActive])
  @@map("countries")
}

model City {
  id                String   @id @default(uuid()) @db.Uuid
  countryId         String   @map("country_id") @db.Uuid
  name              String
  region            String?
  postalCodePattern String?  @map("postal_code_pattern")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  country       Country        @relation(fields: [countryId], references: [id], onDelete: Restrict)
  addresses     UserAddress[]
  warehouses    Warehouse[]
  shippingZones ShippingZone[]
  taxRates      TaxRate[]

  @@unique([countryId, name, region])
  @@index([countryId, name])
  @@index([isActive])
  @@map("cities")
}

model Currency {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.Char(3)
  name          String
  symbol        String
  decimalPlaces Int      @default(2) @map("decimal_places")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userProfiles UserProfile[]
  stores       Store[]

  @@index([isActive])
  @@map("currencies")
}

model Language {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  name      String
  direction Direction @default(LTR)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  userProfiles        UserProfile[]
  categoryTranslations CategoryTranslation[]
  productTranslations  ProductTranslation[]
  cmsTranslations      CmsPageTranslation[]
  voiceSearches        VoiceSearch[]

  @@index([isActive])
  @@map("languages")
}

model UserAddress {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  countryId     String    @map("country_id") @db.Uuid
  cityId        String?   @map("city_id") @db.Uuid
  label         String?
  recipientName String    @map("recipient_name")
  phone         String
  line1         String
  line2         String?
  postalCode    String?   @map("postal_code")
  isDefault     Boolean   @default(false) @map("is_default")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  metadata      Json?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)
  city    City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([countryId, cityId])
  @@map("user_addresses")
}

model Vendor {
  id             String       @id @default(uuid()) @db.Uuid
  legalName      String       @unique @map("legal_name")
  displayName    String       @map("display_name")
  taxIdEncrypted String?      @map("tax_id_encrypted")
  status         VendorStatus @default(PENDING)
  kycStatus      KycStatus    @default(NOT_STARTED) @map("kyc_status")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(6)
  metadata       Json?

  stores       Store[]
  userRoles    UserRole[]
  vendorUsers  VendorUser[]
  departments  Department[]
  employees    VendorEmployee[]
  suppliers    Supplier[]
  apiKeys      ApiKey[]
  subscriptions Subscription[]

  @@index([status])
  @@index([kycStatus])
  @@map("vendors")
}

model VendorUser {
  id        String    @id @default(uuid()) @db.Uuid
  vendorId  String    @map("vendor_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  title     String?
  isOwner   Boolean   @default(false) @map("is_owner")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vendorId, userId])
  @@index([userId])
  @@map("vendor_users")
}

model Store {
  id                String      @id @default(uuid()) @db.Uuid
  vendorId          String      @map("vendor_id") @db.Uuid
  defaultCurrencyId String      @map("default_currency_id") @db.Uuid
  name              String
  slug              String      @unique
  description       String?
  logoUrl           String?     @map("logo_url")
  status            StoreStatus @default(DRAFT)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?   @map("deleted_at") @db.Timestamptz(6)
  metadata          Json?

  vendor          Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  defaultCurrency Currency     @relation(fields: [defaultCurrencyId], references: [id], onDelete: Restrict)
  products        Product[]
  warehouses      Warehouse[]
  orders          Order[]
  userRoles       UserRole[]
  collections     Collection[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@index([status])
  @@map("stores")
}

model Brand {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @unique
  slug       String    @unique
  logoUrl    String?   @map("logo_url")
  isVerified Boolean   @default(false) @map("is_verified")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  metadata   Json?

  products Product[]

  @@index([isVerified])
  @@map("brands")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  name      String
  slug      String
  level     Int       @default(0)
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  metadata  Json?

  parent       Category?             @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children     Category[]            @relation("CategoryTree")
  translations CategoryTranslation[]
  products     Product[]

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

model CategoryTranslation {
  id          String    @id @default(uuid()) @db.Uuid
  categoryId  String    @map("category_id") @db.Uuid
  languageId  String    @map("language_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageId])
  @@index([languageId])
  @@map("category_translations")
}

model Product {
  id          String            @id @default(uuid()) @db.Uuid
  storeId     String            @map("store_id") @db.Uuid
  brandId     String?           @map("brand_id") @db.Uuid
  categoryId  String            @map("category_id") @db.Uuid
  name        String
  slug        String
  description String
  status      ProductStatus     @default(DRAFT)
  visibility  ProductVisibility @default(PUBLIC)
  basePrice   Decimal           @map("base_price") @db.Decimal(12, 2)
  currencyCode String           @map("currency_code") @db.Char(3)
  aiScore     Decimal           @default(0) @map("ai_score") @db.Decimal(5, 2)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz(6)
  metadata    Json?

  store              Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  brand              Brand?                 @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category           Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants           ProductVariant[]
  images             ProductImage[]
  videos             ProductVideo[]
  models3d           Product3dModel[]
  arModels           ProductArModel[]
  assets360          Product360Asset[]
  specifications     ProductSpecification[]
  productAttributes  ProductAttribute[]
  translations       ProductTranslation[]
  embeddings         ProductEmbedding[]
  wishlistItems      WishlistItem[]
  recentlyViewed     RecentlyViewedProduct[]
  recommendations    AiRecommendation[]
  orderItems         OrderItem[]
  reviews            Review[]
  questions          Question[]
  searchClicks       SearchHistory[]
  imageSearchMatches ImageSearchProduct[]
  analyticsEvents    AnalyticsEvent[]
  collectionProducts CollectionProduct[]
  compareItems       CompareItem[]

  @@unique([storeId, slug])
  @@index([categoryId, status, createdAt])
  @@index([brandId])
  @@index([storeId, status])
  @@index([aiScore(sort: Desc)])
  @@map("products")
}

model ProductTranslation {
  id             String    @id @default(uuid()) @db.Uuid
  productId      String    @map("product_id") @db.Uuid
  languageId     String    @map("language_id") @db.Uuid
  name           String
  description    String
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([productId, languageId])
  @@index([languageId])
  @@map("product_translations")
}

model ProductVariant {
  id             String        @id @default(uuid()) @db.Uuid
  productId      String        @map("product_id") @db.Uuid
  sku            String        @unique
  barcode        String?
  price          Decimal       @db.Decimal(12, 2)
  compareAtPrice Decimal?      @map("compare_at_price") @db.Decimal(12, 2)
  currencyCode   String        @map("currency_code") @db.Char(3)
  weightGrams    Int?          @map("weight_grams")
  status         VariantStatus @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)
  metadata       Json?

  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  images           ProductImage[]
  productAttributes ProductAttribute[]
  inventoryItems   InventoryItem[]
  stockMovements   StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  cartItems        CartItem[]
  wishlistItems    WishlistItem[]
  orderItems       OrderItem[]

  @@unique([productId, sku])
  @@index([productId])
  @@index([status])
  @@map("product_variants")
}

model ProductImage {
  id                 String    @id @default(uuid()) @db.Uuid
  productId          String    @map("product_id") @db.Uuid
  variantId          String?   @map("variant_id") @db.Uuid
  cloudinaryPublicId String    @map("cloudinary_public_id")
  url                String
  altText            String?   @map("alt_text")
  sortOrder          Int       @default(0) @map("sort_order")
