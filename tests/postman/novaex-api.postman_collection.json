{
  "info": {
    "name": "NOVAEX API",
    "description": "Newman-compatible NOVAEX enterprise API test collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "productId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health/live"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('body has ok status', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data?.status || json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Readiness",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health/ready"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('readiness responds', () => pm.expect([200,503]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "OAuth Providers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/oauth/providers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newman-{{$timestamp}}@novaex.test\",\n  \"password\": \"Novaex!Secure123\",\n  \"firstName\": \"Newman\",\n  \"lastName\": \"Tester\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('registration accepted', () => pm.expect([201,409]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Rejects Invalid Payload",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bad\",\n  \"password\": \"short\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('validation fails', () => pm.response.to.have.status(400));"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?page=1&limit=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const payload = json.data || json;",
                  "pm.test('products array exists', () => pm.expect(payload.products).to.be.an('array'));",
                  "if (payload.products.length > 0) {",
                  "  pm.collectionVariables.set('productId', payload.products[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Product Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('productId')) {",
                  "  pm.test.skip('no product id from list');",
                  "} else {",
                  "  pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Security",
      "item": [
        {
          "name": "Protected Route Without Token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('unauthorized', () => pm.response.to.have.status(401));"]
              }
            }
          ]
        },
        {
          "name": "SQL Injection Search",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?search='; DROP TABLE users; --"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('search does not crash API', () => pm.expect(pm.response.code).to.be.below(500));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Growth",
      "item": [
        {
          "name": "List Blog Posts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/growth/blog?limit=5"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('blog list responds', () => pm.expect(pm.response.code).to.eql(200));"]
              }
            }
          ]
        }
      ]
    }
  ]
}
